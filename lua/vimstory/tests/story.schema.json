{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gnodar01/vimstory/raw/refs/heads/main/lua/vimstory/tests/story.schema.json",
  "title": "Story Schema",
  "$defs": {
    "storyNode": {
      "type": "object",
      "description": "Story node",
      "properties": {
        "storyNames": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "file": {
          "type": "string"
        },
        "lineStart": {
          "type": "integer",
          "min": 0
        },
        "colStart": {
          "type": "integer",
          "min": 0
        },
        "lineEnd": {
          "type": "integer",
          "min": 0
        },
        "colEnd": {
          "type": "integer",
          "min": 0
        }
      },
      "required": [
        "storyNames",
        "file",
        "lineStart",
        "colStart",
        "lineEnd",
        "colEnd"
      ],
      "additionalProperties": false
    }
  },
  "description": "Schema of a story attached to a git sha",
  "type": "object",
  "properties": {
    "rootPath": {
      "description": "Absolute path to root of project directory (hash should match filename without file ext)",
      "type": "string",
      "pattern": "^/.*$"
    },
    "activeStory": {
      "description": "Currently active story for the project",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "patternProperties": {
    "^(?!rootPath$).*": {
      "description": "A story",
      "type": "object",
      "properties": {
        "description": {
          "type": "string"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "nodes": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/storyNode"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "description",
        "commit",
        "nodes"
      ]
    }
  },
  "required": [
    "rootPath",
    "activeStory"
  ],
  "additionalProperties": false
}
